# REDFORGE Environment Variables

# ===== PROVIDER SELECTION =====
# Choose: "groq" (free tier) or "vertex" (Google Cloud)
REDFORGE_PROVIDER=groq

# ===== Attacker LLM API key (OpenAI) - optional if using Groq/Vertex =====
OPENAI_API_KEY=sk-your-openai-key-here

# ===== Judge LLM API key (Anthropic) - optional if using Groq/Vertex =====
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ===== Target system API key =====
TARGET_API_KEY=your-target-api-key-here

# ===== Groq API keys (FREE tier) =====
# Option A: comma-separated
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4,gsk_key5
# Option B: numbered (supports up to 10)
GROQ_API_KEY_1=gsk_your-groq-key-1-here
GROQ_API_KEY_2=gsk_your-groq-key-2-here
GROQ_API_KEY_3=gsk_your-groq-key-3-here
GROQ_API_KEY_4=gsk_your-groq-key-4-here
GROQ_API_KEY_5=gsk_your-groq-key-5-here

# ===== Google Cloud Vertex AI (if REDFORGE_PROVIDER=vertex) =====
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or run: gcloud auth application-default login
