# REDFORGE Environment Variables

# Attacker LLM API key (OpenAI) - optional if using Groq
OPENAI_API_KEY=sk-your-openai-key-here

# Judge LLM API key (Anthropic) - optional if using Groq
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Target system API key
TARGET_API_KEY=your-target-api-key-here

# Groq API keys (FREE tier - recommended for cost-free operation)
# Option A: comma-separated
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4,gsk_key5
# Option B: numbered (supports up to 10)
GROQ_API_KEY_1=gsk_your-groq-key-1-here
GROQ_API_KEY_2=gsk_your-groq-key-2-here
GROQ_API_KEY_3=gsk_your-groq-key-3-here
GROQ_API_KEY_4=gsk_your-groq-key-4-here
GROQ_API_KEY_5=gsk_your-groq-key-5-here
